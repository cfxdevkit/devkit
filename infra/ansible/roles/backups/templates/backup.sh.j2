#!/bin/bash
# backup.sh — Restic backup script for cfxdevkit VPS
# Generated by Ansible. Do not edit manually.
set -euo pipefail

export RESTIC_REPOSITORY="{{ restic_repository }}"
export RESTIC_PASSWORD="{{ restic_password }}"
{% if b2_account_id %}
export B2_ACCOUNT_ID="{{ b2_account_id }}"
export B2_ACCOUNT_KEY="{{ b2_application_key }}"
{% endif %}

BACKUP_PATHS="{{ backup_paths | join(' ') }}"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Starting restic backup"

# Initialise repo if it doesn't exist yet (idempotent)
restic snapshots &>/dev/null || restic init

# Backup
restic backup $BACKUP_PATHS \
  --tag cfxdevkit-vps \
  --exclude "*.log" \
  --exclude "node_modules"

# Enforce retention policy
restic forget \
  --keep-daily  {{ restic_keep_daily }} \
  --keep-weekly {{ restic_keep_weekly }} \
  --keep-monthly {{ restic_keep_monthly }} \
  --prune

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Backup complete"
